@model Exam

<div class="card">
    <h2>İmtahan məlumatı</h2>

    <p><strong>Dərsin kodu:</strong> @Model.SubjectCode</p>
    <p><strong>Şagird nömrəsi:</strong> @Model.StudentNumber</p>
    <p><strong>Tarix:</strong> @Model.ExamDate.ToString("yyyy-MM-dd")</p>
    <p><strong>Qiymət:</strong> @Model.Grade</p>

    <p>
        <a asp-action="Edit" asp-route-id="@Model.Id">Redaktə</a> |
        <a asp-action="Index">Geri</a>
    </p>
</div>

@model Exam

<div class="card">
    <h2>İmtahanı redaktə et</h2>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <label asp-for="SubjectCode">Dərsin kodu</label>
        <select asp-for="SubjectCode" asp-items="ViewBag.Subjects"></select>

        <label asp-for="StudentNumber">Şagirdin nömrəsi</label>
        <select asp-for="StudentNumber" asp-items="ViewBag.Students"></select>

        <label asp-for="ExamDate">İmtahan tarixi</label>
        <input asp-for="ExamDate" type="date" />

        <label asp-for="Grade">Qiyməti</label>
        <input asp-for="Grade" type="number" min="0" max="9" />

        <div style="margin-top: 12px;">
            <button type="submit">Yadda saxla</button>
            <a asp-action="Index" style="margin-left: 10px;">Geri</a>
        </div>
    </form>
</div>
